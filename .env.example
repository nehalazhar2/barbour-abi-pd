# Barbour ABI
BARBOURABI_API_KEY=
BARBOURABI_USERNAME=
# IMPORTANT: wrap the password in double quotes if it contains "#", "$", or whitespace —
# dotenv treats "#" as a comment and will silently truncate the value otherwise.
BARBOURABI_PASSWORD=
BARBOURABI_ADD_TAG=Add to CRM
BARBOURABI_CRM_TAG=CRM
# Plural form supports multiple comma-separated saved searches. The singular form
# is still read as a fallback single entry.
BARBOURABI_SAVED_SEARCH_NAMES=Housing - Gleeson
BARBOURABI_SAVED_SEARCH_NAME=Housing - Gleeson
BARBOURABI_ROLES=               # Leave blank for all roles, or e.g. "Client,Contractor"
# Always dropped, even if BARBOURABI_ROLES is blank. Leave blank for no exclusions.
BARBOURABI_EXCLUDE_ROLES=
# Primary Lead pairing — independent picks for Org and Contact (case-insensitive exact match).
# NOTE: Barbour has no role named "Main Contractor" — use "Contractor" (Barbour id=40).
PRIMARY_ORG_ROLE=Contractor
PRIMARY_CONTACT_ROLE=Civil engineer
# Fallback chain for PRIMARY_ORG_ROLE only.
PRIMARY_ROLE_PREFERENCE=Contractor,Client,Developer
# Hours of lookback for filter-based sync
BARBOURABI_FILTER_LOOKBACK_HOURS=24
# Shell-lead placeholder used when a project has no usable roles.
BARBOURABI_SHELL_ORG_NAME=Barbour ABI – Awaiting role data
BARBOURABI_SHELL_COMPANY_ID=0

# Pipedrive
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_PIPELINE_ID=
PIPEDRIVE_STAGE_ID=
PIPEDRIVE_OWNER_ID=
PIPEDRIVE_DEFAULT_OWNER_ID=
# Per-tagger ownership: "barbourUserId:pipedriveUserId,barbourUserId:pipedriveUserId"
PIPEDRIVE_OWNER_MAP=

# Lead labels
PD_LABEL_LEAD_BARBOUR=
PD_LABEL_LEAD_TAG_SYNC=
PD_LABEL_LEAD_FILTER_SYNC=

# Public PD app URL — used for org/person hyperlinks in note bodies.
PIPEDRIVE_APP_BASE_URL=

# ─── Pipedrive Custom Field Hash Keys ──────────────────────────────────────────
# Lead (Deal entity custom fields — Leads inherit from Deal)
PD_FIELD_LEAD_BARBOUR_ID=
# Legacy field populated manually by client's team before this integration existed.
# Used as a second dedup lookup so existing Leads are adopted, not duplicated.
PD_FIELD_LEAD_BARBOUR_ID_LEGACY=
PD_FIELD_LEAD_LAST_UPDATED=
PD_FIELD_LEAD_IRONWORK=
PD_FIELD_LEAD_BARBOUR_VALUE=
PD_FIELD_LEAD_GEOWORKS=
PD_FIELD_LEAD_BARBOUR_URL=
PD_FIELD_LEAD_SECTOR=
PD_FIELD_LEAD_POSTCODE=
PD_FIELD_LEAD_TOWN=
PD_FIELD_LEAD_STATUS=
PD_FIELD_LEAD_START_DATE=

# Organisation
PD_FIELD_ORG_BARBOUR_ID=
PD_FIELD_ORG_ROLE=
PD_FIELD_ORG_PHONE=

# Person
PD_FIELD_PERSON_BARBOUR_ID=

# Per-role Org fields on the Lead/Deal
PD_FIELD_LEAD_ORG_CLIENT=
PD_FIELD_LEAD_ORG_CONTRACTOR=
PD_FIELD_LEAD_ORG_ARCHITECT=
PD_FIELD_LEAD_ORG_QS=
PD_FIELD_LEAD_ORG_STRUCTURAL=
PD_FIELD_LEAD_ORG_ME_CONSULTANT=
PD_FIELD_LEAD_ORG_CIVIL=
PD_FIELD_LEAD_ORG_PROJECT_MANAGER=
PD_FIELD_LEAD_ORG_DEVELOPER=
PD_FIELD_LEAD_ORG_TRANSPORT=
PD_FIELD_LEAD_ORG_AGENT=
PD_FIELD_LEAD_ORG_PLANNER=
PD_FIELD_LEAD_ORG_SUSTAINABILITY=
PD_FIELD_LEAD_ORG_GROUNDWORKS=
PD_FIELD_LEAD_ORG_DRAINAGE=

# Product Percentages (as decimals — 0.004% = 0.00004)
PRODUCT_PCT_IRONWORK=0.00004
PRODUCT_PCT_GEOWORKS=0.00004

# Alert Email (Resend) — https://resend.com
RESEND_API_KEY=
ALERT_EMAIL_FROM=
ALERT_EMAIL=

# Dry run — when "true", Pipedrive writes and Barbour tag swaps are logged + skipped.
DRY_RUN=false
# Cap per sync (0 = unlimited). Used to scope first live tests safely.
MAX_PROJECTS_PER_SYNC=0

# Schedule
CRON_SCHEDULE=0 7 * * *
# Set to "true" to also run the sync once on process start
RUN_ON_START=false

# Logging
LOG_LEVEL=info
